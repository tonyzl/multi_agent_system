# ── .env.example — Sistema Multi-Agente TechCorp ─────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el archivo .env al repositorio.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# Modelos usados (opcionales — estos son los valores por defecto)
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
ROUTING_MODEL=gpt-4o-mini

# ── Langfuse (Observabilidad) ─────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Configuración del Sistema ─────────────────────────────────────────────────
# Número de chunks a recuperar por consulta (top-k)
TOP_K=4

# Tamaño de chunk en caracteres
CHUNK_SIZE=600

# Solapamiento entre chunks en caracteres
CHUNK_OVERLAP=100
